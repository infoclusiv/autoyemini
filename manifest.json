{
   "action": {
      "default_title": "__MSG_extName__"
   },
   "background": {
      "service_worker": "background/background.js"
   },
   "content_scripts": [ {
      "js": [
         "config.js",
         "shared/utils.js",
         "content/domInteraction.js",
         "content/providers/chatgpt/domScraper.js",
         "content/providers/chatgpt/webSearchEnabler.js",
         "content/providers/chatgpt/questionSubmitter.js",
         "content/providers/chatgpt/sseHandler.js",
         "content/content.js"
      ],
      "matches": [ "https://chatgpt.com/*" ],
      "run_at": "document_start"
   }, {
      "js": [
         "config.js",
         "shared/utils.js",
         "content/domInteraction.js",
         "content/providers/generic/domScraper.js",
         "content/providers/generic/questionSubmitter.js",
         "content/content.js"
      ],
      "matches": [ "https://*/*", "http://*/*" ],
      "exclude_matches": [ "https://chatgpt.com/*" ],
      "run_at": "document_start"
   } ],
   "default_locale": "en",
   "description": "__MSG_extDescription__",
   "host_permissions": [ "https://chatgpt.com/*", "https://*/*", "http://*/*" ],
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "__MSG_extName__",
   "permissions": [ "storage", "sidePanel", "tabs", "activeTab", "scripting", "alarms" ],
   "side_panel": {
      "default_path": "sidepanel.html"
   },
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0.0",
   "web_accessible_resources": [ {
      "matches": [ "https://chatgpt.com/*" ],
      "resources": [ "injected.js" ]
   } ]
}
